{
  "name": "mobile-e2e-framework",
  "version": "1.0.0",
  "description": "Enterprise Appium E2E Automation Framework for Android Application",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 60000",
    "test:apk": "cross-env APP_TYPE=apk mocha tests/**/*.test.js --timeout 60000",
    "test:installed": "cross-env APP_TYPE=installed mocha tests/**/*.test.js --timeout 60000",
    "test:mock": "cross-env MOCK_DRIVER=true mocha tests/**/*.test.js --timeout 60000",
    "report": "marge mochawesome-report/mochawesome.json -o mochawesome-report/html"
  },
  "keywords": [
    "appium",
    "android",
    "e2e",
    "automation",
    "nodejs",
    "mocha",
    "chai"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "appium": "^2.5.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "winston": "^3.12.0"
  },
  "devDependencies": {
    "chai": "^4.4.1",
    "mocha": "^10.3.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "webdriverio": "^8.34.1"
  }
}
